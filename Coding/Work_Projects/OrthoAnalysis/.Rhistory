library(ggplot2)
diagnosis_alignment <- data.frame(StagesOfCare = c("Preop", "Discharge", "12Month"),
Blounts_means <- rep(c(0), 3),
Blounts_upper2sd <- rep(c(0), 3),
Blounts_lower2sd <- rep(c(0), 3),
Rickets_means <- rep(c(0), 3),
Rickets_upper2sd <- rep(c(0), 3),
Rickets_lower2sd <- rep(c(0), 3),
Others_means <- rep(c(0), 3),
Other_upper2sd <- rep(c(0), 3),
Other_lower2sd <- rep(c(0), 3)
)
colnames(diagnosis_alignment) <- c("StagesOfCare", "Blounts_means", "Blounts_upper2sd", "Blounts_lower2sd", "Rickets_means", "Rickets_upper2sd", "Rickets_lower2sd", "Others_means",
"Others_upper2sd", "Others_lower2sd")
# Indicies for plot
blounts_incidies <- cohort_assess_preop$DIagnosis == "blounts"
rickets_indicies <- cohort_assess_preop$DIagnosis == "rickets"
others_indicies <- cohort_assess_preop$DIagnosis == "others"
diagnosis_alignment$Blounts_means[1] <- mean(as.numeric(cohort_assess_preop$cleaned_Alignment..V2..in.cm[blounts_incidies]))
diagnosis_alignment$Blounts_means[2] <-  mean(as.numeric(cohort_assess_discharge$cleaned_Alignment..V2..in.cm[blounts_incidies]))
diagnosis_alignment$Blounts_means[3] <-  mean(as.numeric(cohort_assess_12month$cleaned_Alignment..V2..in.cm[blounts_incidies]))
diagnosis_alignment$Blounts_upper2sd[1] <- diagnosis_alignment$Blounts_means[1] + 2*sd(as.numeric(cohort_assess_preop$cleaned_Alignment..V2..in.cm[blounts_incidies]))
diagnosis_alignment$Blounts_upper2sd[2] <- diagnosis_alignment$Blounts_means[2] + 2*sd(as.numeric(cohort_assess_discharge$cleaned_Alignment..V2..in.cm[blounts_incidies]))
diagnosis_alignment$Blounts_upper2sd[3] <- diagnosis_alignment$Blounts_means[3] + 2*sd(as.numeric(cohort_assess_12month$cleaned_Alignment..V2..in.cm[blounts_incidies]))
diagnosis_alignment$Blounts_lower2sd[1] <- diagnosis_alignment$Blounts_means[1] - 2*sd(as.numeric(cohort_assess_preop$cleaned_Alignment..V2..in.cm[blounts_incidies]))
diagnosis_alignment$Blounts_lower2sd[2] <- diagnosis_alignment$Blounts_means[2] - 2*sd(as.numeric(cohort_assess_discharge$cleaned_Alignment..V2..in.cm[blounts_incidies]))
diagnosis_alignment$Blounts_lower2sd[3] <- diagnosis_alignment$Blounts_means[3] - 2*sd(as.numeric(cohort_assess_12month$cleaned_Alignment..V2..in.cm[blounts_incidies]))
diagnosis_alignment$Rickets_means[1] <- mean(as.numeric(cohort_assess_preop$cleaned_Alignment..V2..in.cm[rickets_indicies]))
diagnosis_alignment$Rickets_means[2] <- mean(as.numeric(cohort_assess_discharge$cleaned_Alignment..V2..in.cm[rickets_indicies]))
diagnosis_alignment$Rickets_means[3] <- mean(as.numeric(cohort_assess_12month$cleaned_Alignment..V2..in.cm[rickets_indicies]))
diagnosis_alignment$Rickets_upper2sd[1] <- diagnosis_alignment$Rickets_means[1] + 2*sd(as.numeric(cohort_assess_preop$cleaned_Alignment..V2..in.cm[rickets_indicies]))
diagnosis_alignment$Rickets_upper2sd[2] <- diagnosis_alignment$Rickets_means[2] + 2*sd(as.numeric(cohort_assess_discharge$cleaned_Alignment..V2..in.cm[rickets_indicies]))
diagnosis_alignment$Rickets_upper2sd[3] <- diagnosis_alignment$Rickets_means[3] + 2*sd(as.numeric(cohort_assess_12month$cleaned_Alignment..V2..in.cm[rickets_indicies]))
diagnosis_alignment$Rickets_lower2sd[1] <- diagnosis_alignment$Rickets_means[1] - 2*sd(as.numeric(cohort_assess_preop$cleaned_Alignment..V2..in.cm[rickets_indicies]))
diagnosis_alignment$Rickets_lower2sd[2] <- diagnosis_alignment$Rickets_means[2] - 2*sd(as.numeric(cohort_assess_discharge$cleaned_Alignment..V2..in.cm[rickets_indicies]))
diagnosis_alignment$Rickets_lower2sd[3] <- diagnosis_alignment$Rickets_means[3] - 2*sd(as.numeric(cohort_assess_12month$cleaned_Alignment..V2..in.cm[rickets_indicies]))
diagnosis_alignment$Others_means[1] <- mean(as.numeric(cohort_assess_preop$cleaned_Alignment..V2..in.cm[others_indicies]))
diagnosis_alignment$Others_means[2] <- mean(as.numeric(cohort_assess_discharge$cleaned_Alignment..V2..in.cm[others_indicies]))
diagnosis_alignment$Others_means[3] <- mean(as.numeric(cohort_assess_12month$cleaned_Alignment..V2..in.cm[others_indicies]))
diagnosis_alignment$Others_upper2sd[1] <- diagnosis_alignment$Others_means[1] + 2*sd(as.numeric(cohort_assess_preop$cleaned_Alignment..V2..in.cm[others_indicies]))
diagnosis_alignment$Others_upper2sd[2] <- diagnosis_alignment$Others_means[2] + 2*sd(as.numeric(cohort_assess_discharge$cleaned_Alignment..V2..in.cm[others_indicies]))
diagnosis_alignment$Others_upper2sd[3] <- diagnosis_alignment$Others_means[3] + 2*sd(as.numeric(cohort_assess_12month$cleaned_Alignment..V2..in.cm[others_indicies]))
diagnosis_alignment$Others_lower2sd[1] <- diagnosis_alignment$Others_means[1] - 2*sd(as.numeric(cohort_assess_preop$cleaned_Alignment..V2..in.cm[others_indicies]))
diagnosis_alignment$Others_lower2sd[2] <- diagnosis_alignment$Others_means[2] - 2*sd(as.numeric(cohort_assess_discharge$cleaned_Alignment..V2..in.cm[others_indicies]))
diagnosis_alignment$Others_lower2sd[3] <- diagnosis_alignment$Others_means[3] - 2*sd(as.numeric(cohort_assess_12month$cleaned_Alignment..V2..in.cm[others_indicies]))
