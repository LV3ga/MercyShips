{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyOGvXU21xfyBIL0FS+oA+HM"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"markdown","source":["1. Raw Dataset Creation (no further edits needed)"],"metadata":{"id":"RISy51vGxLaj"}},{"cell_type":"code","source":["##The purpose of this is the come up with a dataset that will include all obs from each date (2005-2023) per country\n","library(WDI)\n","library(dplyr)\n","\n","\n","##**________________________________________________________________________________*\n","##** Creating dataset1_0 dataframe_______________________________________________*\n","\n","#select all World Development indicators (WDI) that you potentially will use;\n","#select only country names and indicator data; datasets will be merged\n","#further information: https://databank.worldbank.org/source/world-development-indicators\n","\n","##Denny will send with the 2 letter code\n","\n","##Maternal mortality ratio (modeled) = SH.STA.MMRT\n","#This is extra=TRUE to get additional information\n","MMRmodelALL=WDI(indicator=c('SH.STA.MMRT'), country='all',start=2005, end=NULL)\n","#MMRmodelALL<-MMRmodelALL[,!names(MMRmodelALL)%in%c(\"iso2c\", \"iso3c\")]\n","#View(MMRmodelALL)\n","\n","##Neonatal Mortality rate per 1,000 live births = SH.DYN.NMRT\n","NeonatalMort=WDI(indicator=c('SH.DYN.NMRT'), country = 'all',start=2005, end=NULL)\n","NeonatalMort<-NeonatalMort[,!names(NeonatalMort)%in%c(\"iso2c\",\"iso3c\")]\n","#View(NeonatalMort)\n","\n","##Mortality Rate infant per 1,000 = SP.DYN.IMRT.IN\n","InfantMort=WDI(indicator=c('SP.DYN.IMRT.IN'), country='all',start=2005, end=NULL)\n","InfantMort<-InfantMort[,!names(InfantMort)%in%c( \"iso2c\", \"iso3c\")]\n","View(InfantMort)\n","\n","##Mortality rate, under 5 = SH.DYN.MORT\n","MortalityUnder5ALL=WDI(indicator=c('SH.DYN.MORT'), country='all',start=2005, end=NULL)\n","MortalityUnder5ALL<-MortalityUnder5ALL[,!names(MortalityUnder5ALL)%in%c(\"iso2c\", \"iso3c\")]\n","View(MortalityUnder5ALL)\n","\n","##Risk Catastrophic expenditure for surgical care = SH.SGR.CRSK.ZS\n","RiskCatExpend=WDI(indicator=c('SH.SGR.CRSK.ZS'), country='all',start=2005, end=NULL)\n","RiskCatExpend<-RiskCatExpend[,!names(RiskCatExpend)%in%c(\"iso2c\", \"iso3c\")]\n","View(RiskCatExpend)\n","\n","##Risk Impoverishing expenditure for surgical care = SH.SGR.IRSK.ZS\n","RiskImpovExpend=WDI(indicator=c('SH.SGR.IRSK.ZS'), country='all',start=2005, end=NULL)\n","RiskImpovExpend<-RiskImpovExpend[,!names(RiskImpovExpend)%in%c(\"iso2c\", \"iso3c\")]\n","View(RiskImpovExpend)\n","\n","##Number of SOA specialists = SH.MED.SAOP.P5\n","NumSOAspecialists=WDI(indicator=c('SH.MED.SAOP.P5'), country='all',start=2005, end=NULL)\n","NumSOAspecialists<-NumSOAspecialists[,!names(NumSOAspecialists)%in%c(\"iso2c\", \"iso3c\")]\n","View(NumSOAspecialists)\n","\n","  ##Number of Nurses/Midwives = SH.MED.NUMW.P3\n","NumNurseMidwives=WDI(indicator=c('SH.MED.NUMW.P3'), country='all',start=2005, end=NULL)\n","NumNurseMidwives<-NumNurseMidwives[,!names(NumNurseMidwives)%in%c(\"iso2c\", \"iso3c\")]\n","View(NumNurseMidwives)\n","\n","##Number of hospital beds = SH.MED.BEDS.ZS\n","NumHospBeds=WDI(indicator=c('SH.MED.BEDS.ZS'), country='all',start=2005, end=NULL)\n","NumHospBeds<-NumHospBeds[,!names(NumHospBeds)%in%c(\"iso2c\", \"iso3c\")]\n","View(NumHospBeds)\n","\n","##Number of Surgical Procedures per 100,000 of population = SH.SGR.PROC.P5\n","NumSxProcedures=WDI(indicator=c('SH.SGR.PROC.P5'), country='all',start=2005, end=NULL)\n","NumSxProcedures<-NumSxProcedures[,!names(NumSxProcedures)%in%c(\"iso2c\", \"iso3c\")]\n","View(NumSxProcedures)\n","\n","##Current Health expenditure per capita = SH.XPD.CHEX.PC.CD\n","HealthExpendperCapita=WDI(indicator=c('SH.XPD.CHEX.PC.CD'), country='all',start=2005, end=NULL)\n","HealthExpendperCapita<-HealthExpendperCapita[,!names(HealthExpendperCapita)%in%c(\"iso2c\", \"iso3c\")]\n","View(HealthExpendperCapita)\n","\n","##Number of Physicians per 1,000 persons = SH.MED.PHYS.ZS\n","NumPhysicians=WDI(indicator=c('SH.MED.PHYS.ZS'), country='all',start=2005, end=NULL)\n","NumPhysicians<-NumPhysicians[,!names(NumPhysicians)%in%c(\"iso2c\", \"iso3c\")]\n","View(NumPhysicians)\n","\n","##Births attended by skilled staff = SH.STA.BRTC.ZS\n","BirthsAttend=WDI(indicator=c('SH.STA.BRTC.ZS'), country='all',start=2005, end=NULL)\n","BirthsAttend<-BirthsAttend[,!names(BirthsAttend)%in%c(\"iso2c\", \"iso3c\")]\n","View(BirthsAttend)\n","\n","##Fertility Rate births per woman = SP.DYN.TFRT.IN\n","FertRate=WDI(indicator=c('SP.DYN.TFRT.IN'), country='all',start=2005, end=NULL)\n","FertRate<-FertRate[,!names(FertRate)%in%c(\"iso2c\", \"iso3c\")]\n","View(FertRate)\n","\n","##GNI per capita Atlas method = NY.GNP.PCAP.CD\n","GNIperCap=WDI(indicator=c('NY.GNP.PCAP.CD'), country='all',start=2005, end=NULL)\n","GNIperCap<-GNIperCap[,!names(GNIperCap)%in%c(\"iso2c\", \"iso3c\")]\n","View(GNIperCap)\n","\n","##Immunization measles children 12-23mo = SH.IMM.MEAS\n","ImmMeasles=WDI(indicator=c('SH.IMM.MEAS'), country='all',start=2005, end=NULL)\n","ImmMeasles<-ImmMeasles[,!names(ImmMeasles)%in%c(\"iso2c\", \"iso3c\")]\n","View(ImmMeasles)\n","\n","##Labour force female % = SL.TLF.TOTL.FE.ZS\n","LabourforceF=WDI(indicator=c('SL.TLF.TOTL.FE.ZS'), country='all',start=2005, end=NULL)\n","LabourforceF<-LabourforceF[,!names(LabourforceF)%in%c(\"iso2c\", \"iso3c\")]\n","View(LabourforceF)\n","\n","##Out of pocket expenditure = SH.XPD.OOPC.CH.ZS\n","OOPexpend=WDI(indicator=c('SH.XPD.OOPC.CH.ZS'), country='all',start=2005, end=NULL)\n","OOPexpend<-OOPexpend[,!names(OOPexpend)%in%c(\"iso2c\", \"iso3c\")]\n","View(OOPexpend)\n","\n","##Population Growth annual % = SP.POP.GROW\n","PopGrowth=WDI(indicator=c('SP.POP.GROW'), country='all',start=2005, end=NULL)\n","PopGrowth<-PopGrowth[,!names(PopGrowth)%in%c(\"iso2c\", \"iso3c\")]\n","View(PopGrowth)\n","\n","##Urban Population Growth annual % = SP.URB.GROW\n","urbanPopGrowth=WDI(indicator=c('SP.URB.GROW'), country='all',start=2005, end=NULL)\n","urbanPopGrowth<-urbanPopGrowth[,!names(urbanPopGrowth)%in%c(\"iso2c\", \"iso3c\")]\n","View(urbanPopGrowth)\n","\n","##Mortality caused by road traffic injury (per 100,000 population) = SH.STA.TRAF.P5\n","roadMort=WDI(indicator=c('SH.STA.TRAF.P5'), country='all',start=2005, end=NULL)\n","roadMort<-roadMort[,!names(roadMort)%in%c(\"iso2c\",\"iso3c\")]\n","View(roadMort)\n","\n","##INCOME = SH.STA.TRAF.P5\n","Income=WDI(indicator=c('SH.STA.TRAF.P5'), country='all',start=2005, end=NULL, extra=TRUE)\n","Income<-Income[,!names(Income)%in%c(\"SH.STA.TRAF.P5\", \"region\",\"iso2c\", \"iso3c\",\"status\",\"lastupdated\",\"capital\",\"longitude\",\"latitude\",\"lending\")]\n","View(Income)\n","\n","##REGION = SH.STA.TRAF.P5\n","Region=WDI(indicator=c('SH.STA.TRAF.P5'), country='all',start=2005, end=NULL, extra=TRUE)\n","Region<-Region[,!names(Region)%in%c(\"SH.STA.TRAF.P5\", \"income\",\"iso2c\", \"iso3c\",\"status\",\"lastupdated\",\"capital\",\"longitude\",\"latitude\",\"lending\")]\n","View(Region)\n","\n","\n","\n","Final<-merge(MMRmodelALL,NeonatalMort,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,NeonatalMort,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,InfantMort,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,MortalityUnder5ALL,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,RiskCatExpend,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,RiskImpovExpend,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,NumSOAspecialists,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,NumNurseMidwives,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,NumHospBeds,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,NumSxProcedures,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,HealthExpendperCapita,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,NumPhysicians,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,BirthsAttend,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,FertRate,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,GNIperCap,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,ImmMeasles,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,LabourforceF,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,OOPexpend,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,PopGrowth,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,urbanPopGrowth,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,roadMort,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,Income,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-merge(Final,Region,by.x=c(\"country\",\"year\"),by.y=c(\"country\",\"year\"))\n","Final<-Final[!(Final$region==\"Aggregates\"),]\n","\n","View(Final)\n","\n","\n","## Drop countries labeled 'na'\n","library(tidyverse)\n","Final <-Final %>% drop_na(country)\n","View(Final)\n","\n","\n","##Save dataset for easy access**\n","library(readr)\n","write_csv(Final, \"/Users/zprze/Desktop/Mercy Ships/MELD Internship/Predictive Planning Project/R data and code PPP/Final2005.2022.csv\")\n","\n","\n","##Removing unneeded datasets\n","remove(MMRmodelALL)\n","remove(NeonatalMort)\n","remove(InfantMort)\n","remove(MortalityUnder5ALL)\n","remove(RiskCatExpend)\n","remove(RiskImpovExpend)\n","remove(NumSOAspecialists)\n","remove(NumNurseMidwives)\n","remove(NumHospBeds)\n","remove(NumSxProcedures)\n","remove(HealthExpendperCapita)\n","remove(NumPhysicians)\n","remove(BirthsAttend)\n","remove(FertRate)\n","remove(GNIperCap)\n","remove(ImmMeasles)\n","remove(LabourforceF)\n","remove(OOPexpend)\n","remove(PopGrowth)\n","remove(urbanPopGrowth)\n","remove(roadMort)\n","remove(Income)\n","remove(Region)\n","\n"],"metadata":{"id":"U6Bucy5Mx0WB"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["2. Add in the Composit Score as a variable."],"metadata":{"id":"j-fSrWNcx2HF"}},{"cell_type":"code","source":["\n","library(readr)\n","library(dplyr)\n","library(tidyr)\n","Final2005_2022 <- read_csv(\"C:/Users/zprze/Desktop/Mercy Ships/MELD Internship/Predictive Planning Project/R data and code PPP/Final2005.2022.csv\")\n","View(Final2005_2022)\n","\n","##Open the composit score dataset\n","library(readxl)\n","Country_Health_System_Composite_Score2 <- read_excel(\"C:/Users/zprze/Downloads/Country - Health System Composite Score.xlsx\")\n","#View(Country_Health_System_Composite_Score2)\n","\n","#Rename column isoc\n","colnames(Country_Health_System_Composite_Score2)[3]=\"iso2c\"\n","colnames(Country_Health_System_Composite_Score2)[2]=\"CompositScore\"\n","\n","#Remove the full country name colummn\n","Country_Health_System_Composite_Score1<-Country_Health_System_Composite_Score2[-c(1)]\n","#View(Country_Health_System_Composite_Score1)\n","\n","#Merge the dataframes\n","Final2005_2022_2<-left_join(Final2005_2022,Country_Health_System_Composite_Score1, by = join_by(\"iso2c\"))\n","View(Final2005_2022_2)\n","\n","#cleaning up edata enfironment:\n","remove(Country_Health_System_Composite_Score1)\n","remove(Country_Health_System_Composite_Score2)\n","remove(Final2005_2022)"],"metadata":{"id":"3QkHwvhJyZPx"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["3. Make the dataset even smaller/simpler so that it can be more quickly imputed ((I've chosen to do this by making a dataset with zero missingness amongst the variables number of surgical procedures and number of SAOP providers - but can be done totally differentlay too))\n","\n","\n","\n"],"metadata":{"id":"BfSfSqOmyaWR"}},{"cell_type":"code","source":["##Making a smaller Dataset for easier imputations\n","#Making a dataset with zero missingness of the variable surgical procedures(SH.SGR.PROC.P5):\n","SurgProcs_notImputed<-Final2005_2022_2%>%drop_na(SH.SGR.PROC.P5)\n","#View(SurgProcs_notImputed)\n","##Making a dataset with zero missingness of the variable SAOP providers(SH.MED.SAOP.P5):\n","SaopDocs_notImputed<-Final2005_2022_2%>%drop_na(SH.MED.SAOP.P5)\n","#View(SaopDocs_notImputed)\n","##Making a dataset with zero missigness of the variables surgical procedures (SH.SGR.PROC.P5) and SAOP providers(SH.MED.SAOP.P5):\n","SurgSaop_notImputed<-merge(SaopDocs_notImputed,SurgProcs_notImputed) ##**This is the one i'm using**\n","View(SurgSaop_notImputed)\n","##Remove unnecessary\n","remove(SurgProcs_notImputed)\n","remove(SaopDocs_notImputed)"],"metadata":{"id":"21cX-RYxzCd_"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["4. Run the imputation code in a way that excludes the CompositScore variable from being used during imputation calculations\n","- I used a maxit & m of 5 to make this run more quickly\n","-\n","-\n","-\n","*** Chage the income and region variables from character to catagorical so they can be used in iputation (?)"],"metadata":{"id":"VCQ8x2u0zGDI"}},{"cell_type":"code","source":["library(mice) #multiple imputations\n","library(mgcv) #GAMs\n","#First do a dry run, set the predictorMatrix, then run the real imputation\n","#(method from this response: https://stackoverflow.com/questions/53543274/include-id-variable-in-imputed-data-frame)\n","dryRUN<-mice(SurgSaop_notImputed,maxit=0)\n","  pred1<-dryRUN$predictorMatrix\n","  pred1[,'CompositScore']<-0\n","\n","#Imputation\n","SurgSaop_IMP_5 <- mice(SurgSaop_notImputed, pred=pred1, m=5,meth='pmm',maxit=5)\n","  ##**Will be m=250 and maxit at least 20; 5 &5 used for now for time saving\n"],"metadata":{"id":"iadrckd7zUmM"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["5. Now we have our imputed dataset in the format of a list of class \"mids\". We are first going to complete that list into multiple data.frames and then use a loop to rename ewach of the data.frames with a unique name. (There's method 1 and Method 2 - I don't know which is best as you move into the next stages)\n"],"metadata":{"id":"CDHWc-Wr48qs"}},{"cell_type":"code","source":["##Method 1: USE THIS to complete from 'mids' object (class(SurgSaop_IMP_5=mids)) into multiple data.frames\n","SurgSaop_IMP_all<-complete(SurgSaop_IMP_5, action = 'all', include=FALSE, mild = FALSE)\n","#typeof = list; class = \"mild\"\"list\"\n","##Assign unique names\n","names(SurgSaop_IMP_all)<-paste0(\"imputed_data_ALL_\", 1:length(SurgSaop_IMP_all))"],"metadata":{"id":"l1Ub8ZFN5Om1"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["##Method 2: USE lapply to complete as a list\n","SurgSaop_IMP_list<-lapply(SurgSaop_IMP_all, complete)\n","#typeof = list, class = list\n","##Assign unique names\n","names(SurgSaop_IMP_list)<-paste0(\"imputed_data_LIST_\", 1:length(SurgSaop_IMP_list))"],"metadata":{"id":"VIiyhxVh5g1e"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["5.1 -- I don't think you need this step.... but it brings your dataframes into your enviornment, and then puts them back together into a list..."],"metadata":{"id":"2i7RgxBO5uq5"}},{"cell_type":"code","source":["##Now saves the dataframes into your enviornment, can be used with method 2 and method 3\n","list2env(SurgSaop_IMP_list, .GlobalEnv)\n","\n","##**This is the exact same list of data.frames as SurgSaop_IMP_all*\n","##To put all of the imputed datasets into a list:\n","imputed_data_list<-list()\n","#loop for numbers 1-65\n","for (i in 1:5){\n","  dataset_name<-paste0(\"imputed_data_list_\",i)\n","  imputed_data_list[[i]]<-get(dataset_name)\n","}"],"metadata":{"id":"g9L4Ktio6Lwm"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["6. Now we get into GAM. We assign our GAM formula ((again, can be totally changed)). We then make a list for the results to move to, rename each with  unique identifier, and can extract them into our enviornment if desired."],"metadata":{"id":"_WGcbwYz6m8k"}},{"cell_type":"code","source":["##To run the GAM with each of the datasets in the list, and put the results into another list\n","formula_gam<-formula(SH.SGR.PROC.P5 ~ s(SH.MED.SAOP.P5) + s(SH.XPD.CHEX.PC.CD))\n","fitted_gams_ALL<-list()\n","for (i in seq_along(SurgSaop_IMP_all)) {\n","  current_data<-SurgSaop_IMP_all[[i]]\n","  fitted_gams_ALL[[i]]<-gam(formula_gam, data= current_data)\n","}\n","\n","typeof(fitted_gams_ALL) #list\n","class(fitted_gams_ALL) #list\n","\n","##Assign meaningful names\n","names(fitted_gams_ALL)<-paste0(\"fitted_gams_ALL_\", 1:length(fitted_gams_ALL))\n","\n","#Saving to global enviornment just to take a look\n","list2env(fitted_gams_ALL, .GlobalEnv) ##Still a list"],"metadata":{"id":"PFOGojy8-JmD"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["7. Now we have our imputed datasets, our gam model, and our results from using the gam on each dataset. We now need to pool the results to get a final value for each statistical measurement.\n","- I used the pooling methods from this website (download the html file): http://www.daviddisabato.com/blog/2021/2/13/analyzing-and-pooling-results-from-multiply-imputed-data\n","- This outlines 3 methods: Manual, miTools, and MICE\n","- ((I wrote a comment and he replied that he wasn't familiar with GAMs))\n","- I also tried Chat GPT which ran me in circles and dead-ends --> it was most similarly following the 'Manual' method above\n","-\n","-\n","-\n","I'm putting some of the code below that I was trying.. The Manual is the one I got furthest with/worked the best for me, but there's issues when you print out the results.\n","-\n","-\n","- Other posts I ran into but haven't persued:\n","- https://stats.stackexchange.com/questions/100245/how-to-summarize-gam-model-result-from-multiple-imputation-data-in-r\n","-"],"metadata":{"id":"m_HmDaO1-faA"}},{"cell_type":"code","source":["##MANUAL\n","##SurgSaop_IMP_list\n","##To run the GAM with each of the datasets in the list, and put the results into another list\n","formula_gam<-formula(SH.SGR.PROC.P5 ~ s(SH.MED.SAOP.P5) + s(SH.XPD.CHEX.PC.CD))\n","fitted_gams_LIST<-list()\n","for (i in seq_along(SurgSaop_IMP_list)) {\n","  current_data<-SurgSaop_IMP_list[[i]]\n","  fitted_gams_LIST[[i]]<-gam(formula_gam, data= current_data)\n","}\n","lapply(X=fitted_gams_LIST[1:i],FUN=summary) #seeing the summaries of all\n","#extract statistical information from each regression model:\n","\n","#list of coefficients\n","coef_imp<-lapply(X=fitted_gams_LIST,FUN=coef)\n","print(coef_imp[1:i])\n","\n","#list of variance-covariance matrix\n","vcov_imp<-lapply(X=fitted_gams_LIST,FUN=vcov)\n","print(vcov_imp[1]) ##**Why does this return variable.1-variable.9?.. because I did not do a variable x variable analysis (ie 2x2 but rather 2 x 20ish)*\n","\n","#use str2str to put them together\n","library(str2str)\n","coef_mat<-lv2m(coef_imp,along=1)\n","print(coef_mat[1:i,])\n","\n","vcov_ary<-lm2a(vcov_imp)\n","print(vcov_ary[,,1:i])\n","\n","#regression coefficients: by taking the mean across each imputed dataset (usual mean calculated in statistics)\n","coef_pool<-colMeans(coef_mat[1:i,])\n","print(coef_pool)\n","\n","\n","#VCOV\n","sample_size<-apply(X=vcov_ary,MARGIN=c(1,2), FUN=mean)\n","print(sample_size)"],"metadata":{"id":"DovK8ucdANlb"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["#using mitools\n","library(mitools)\n","\n","attitude_impList<-imputationList(SurgSaop_IMP_list)\n","summary(attitude_impList)\n","\n","\n","lm_imp2<-with(attitude_impList, gam(SH.SGR.PROC.P5 ~ s(SH.MED.SAOP.P5) + s(SH.XPD.CHEX.PC.CD)))\n","              head(lm_imp2,n=3)\n","\n","\n","coef_imp2<-MIextract(results=fitted_gams_ALL, fun=coef)\n","head(coef_imp2,n=1)\n","\n","vcov_imp2<-MIextract(results=fitted_gams_ALL,fun=vcov)\n","head(vcov_imp2,n=1)\n","\n","#MIcombine funtion\n","df_com2 <- df.residual(lm_imp2[[1]])\n","all_pool <- MIcombine(results = coef_imp2, variances = vcov_imp2, df.complete = df_com2)\n","coef_pool2 <- all_pool[[\"coefficients\"]]\n","se_pool2 <- sqrt(diag(all_pool[[\"variance\"]]))\n","df_imp2 <- all_pool[[\"df\"]]\n","t_pool2 <- coef_pool2 / se_pool2\n","p_pool2 <- 2 * pt(q = abs(t_pool2), df = df_imp2, lower.tail = F)\n","fmi2 <- all_pool[[\"missinfo\"]]\n","result_pool2 <- data.frame(\"est\" = coef_pool2, \"se\" = se_pool2, \"t\" = t_pool2,\n","                           \"df\" = df_imp2, \"p\" = p_pool2, \"fmi\" = fmi2)\n","print(result_pool2)\n"],"metadata":{"id":"Fwx90CD2_VGh"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["\n","##And again another try\n","library(mice)\n","library(mgcv)\n","\n","SurgSaop_IMP <- mice(SurgSaop_notImputed, m = 5, meth = 'pmm', maxit = 5)\n","\n","## Complete into multiple data.frames\n","SurgSaop_IMP_all <- complete(SurgSaop_IMP, action = 'all', include = FALSE)\n","\n","## Assign meaningful names\n","names(SurgSaop_IMP_all) <- paste0(\"imputed_data_\", 1:length(SurgSaop_IMP_all))\n","\n","## Now, you don't need list2env()\n","## Instead, you can run the GAM with lapply() and store the results in a list\n","formula_gam <- formula(SH.SGR.PROC.P5 ~ s(SH.MED.SAOP.P5) + s(SH.XPD.CHEX.PC.CD))\n","\n","fitted_gams <- lapply(SurgSaop_IMP_all, function(df) {\n","  gam(formula_gam, data = df)\n","})\n","\n","## Extract coefficient estimates for each term in the formula\n","coefficient_estimates <- lapply(fitted_gams, function(gam_model) {\n","  coef(gam_model)\n","})\n","\n","## Combine the coefficient estimates into a data frame\n","coefficient_estimates_df <- as.data.frame(do.call(rbind, coefficient_estimates))\n","\n","## Calculate the pooled estimates and standard errors\n","pooled_estimates <- colMeans(coefficient_estimates_df)\n","pooled_standard_errors <- apply(coefficient_estimates_df, 2, function(x) {\n","  sqrt(var(x, na.rm = TRUE) / length(na.omit(x)))\n","})\n","\n","## Combine the pooled estimates and standard errors into a data frame\n","pooled_results <- data.frame(\n","  term = names(pooled_estimates),\n","  estimate = pooled_estimates,\n","  std.error = pooled_standard_errors\n",")\n","\n","print(pooled_results)\n","View(pooled_results)\n"],"metadata":{"id":"e2Y7BDIHAspm"},"execution_count":null,"outputs":[]}]}