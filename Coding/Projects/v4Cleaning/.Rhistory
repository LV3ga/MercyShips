require(tidyverse)
X = read_delim('2023mlbBattingStatistics.csv',
delim = ';')
# Step 1.
nms = X$Name
Encoding(nms) = "latin1"
###
# Step 1.
nms <- gsub('[[:punct:]]', '', nms)
X$Name <- nms
# Step 2.
space = '\xa0'
Encoding(space) = 'latin1'
nmsSplit = strsplit(nms, '\\xa0')
#Step 3.
first = sapply(nmsSplit,"[[",1)
last = sapply(nmsSplit, "[[", 2)
X = mutate(X, nameFirst = first, nameLast = last)
#Step 4.
###
X %>% select(-Name) %>%  select(contains('name'),) %>% head(5)
tbl = table(X$Name)
tbl[tbl > 1]
Xdedup = X %>% distinct(Name, .keep_all = TRUE)
dim(Xdedup)
# Splitting
duplicates = X %>% filter(Name %in% names(tbl[tbl>1]))
withoutDuplicates = X %>% filter(!(Name %in% names(tbl[tbl>1])))
i = 1
while( i <= nrow(duplicates)){
print(i)
name = duplicates[i,2]
j = i + 1
while(name == duplicates[j,2] && j <= 30){
duplicates[i,6:18] = duplicates[i,6:18] + duplicates[j,6:18]
j = j + 1
}
withoutDuplicates = rbind(withoutDuplicates, duplicates[i,])
i = j
}
# new dataframe
df = withoutDuplicates
df = df %>% filter(AB >= 20)
dim(df)
df = df %>% mutate('battingAvg' = H/AB, .keep = 'all')
df = df %>% mutate('battingAvg' = H/AB, .keep = 'all')
dim(df)
betaF = function(x,params){
return( dbeta(x, params[1], params[2]) )}
output = optim(par = c(5,5), fn = logLikeF, 'L-BFGS-B', x = df$battingAvg, f = betaF, maximize = FALSE)
output
output$par
aHat = output$par[1]
bHat = output$par[2]
estimatedMean     = aHat / (aHat + bHat)
estimatedVariance = (aHat * bHat) / ((aHat + bHat)**2*(aHat + bHat + 1))
estimatedMean
sqrt(estimatedVariance)
